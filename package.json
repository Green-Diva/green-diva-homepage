{
  "name": "personal-webpage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next .next-dev",
    "dev": "next dev",
    "dev:stable": "npm run build && npm run start",
    "build": "next build",
    "start": "tsx prisma/migrate-token-hash.ts && tsx prisma/migrate-agent-loadout.ts && tsx prisma/migrate-remove-runtime-config.ts && tsx prisma/migrate-remove-classification.ts && tsx prisma/migrate-skill-handlers.ts && tsx prisma/migrate-relic-drafts.ts && tsx prisma/migrate-remove-relic-origin-acquired.ts && prisma db push --skip-generate --accept-data-loss && tsx prisma/migrate-skill-slug.ts && next start",
    "start:stable": "npm run build && npm run start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "@google/model-viewer": "^4.2.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "heic-convert": "^2.1.0",
    "jszip": "^3.10.1",
    "next": "16.2.4",
    "openai": "^6.36.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
