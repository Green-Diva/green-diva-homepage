generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  serial            Int?              @unique
  // Tokens are stored as bcrypt hashes (one-way). tokenLookup is an
  // HMAC-SHA256(token, SAFETY_SECRET) for O(1) login lookup.
  // Plaintext is returned to admins exactly once at issuance.
  tokenHash         String
  tokenLookup       String            @unique
  name              String
  gender            String?
  avatarUrl         String?
  bio               String?
  level             Int               @default(1)
  attack            Int               @default(50)
  defense           Int               @default(50)
  hp                Int               @default(50)
  agility           Int               @default(50)
  luck              Int               @default(50)
  specialAttributes String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          Session[]
  activities        Activity[]
  relicShares       RelicShare[]      @relation("RelicShareRecipient")
  sharedByMe        RelicShare[]      @relation("RelicShareGranter")
  extractedRelics   Relic[]           @relation("RelicExtractor")
  relicGrants       RelicGrant[]      @relation("RelicGrantRecipient")
  grantsIssued      RelicGrant[]      @relation("RelicGrantGranter")
  vaultProfile      VaultProfile?
  vaultItems        VaultItem[]
  agentsCreated    Agent[]
  skillsCreated     Skill[]            @relation("SkillCreator")
  relicDrafts       RelicDraft[]       @relation("RelicDraftUploader")
}

// End-to-end encrypted vault — server stores only ciphertext.
// `salt` + `iterations` are public PBKDF2 parameters; `verifier` is
// HMAC-SHA256("verify", masterKey) so the client can self-check the entered
// master password without ever sending it (or anything derivable from it).
model VaultProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  saltBase64     String
  verifierBase64 String
  iterations     Int      @default(600000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum VaultItemKind {
  PASSWORD
  NOTE
}

model VaultItem {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           VaultItemKind
  dekCiphertext  String
  dekIv          String
  nameCiphertext String
  nameIv         String
  bodyCiphertext String
  bodyIv         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, updatedAt])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  SPECIAL
}

enum RelicStatus {
  DRAFT
  PROCESSING
  // Pipeline finished successfully but admin hasn't confirmed yet. Visible
  // only to admin (yellow-tinted cell in vault grid + review banner on
  // detail page). One-shot transition: confirming flips to READY.
  AWAITING_REVIEW
  READY
  PARTIAL
  FAILED
}

model Relic {
  id                 String               @id @default(cuid())
  slot               Int                  @unique
  slug               String               @unique
  nameEn             String
  nameZh             String
  classifEn          String
  classifZh          String
  rarity             Rarity
  iconKey            String?
  modelPath          String?
  // 2D form: best-pick image (post-Smart Image Picker). Admin can change
  // which candidate is the primary in the review UI.
  primaryImagePath   String?
  // 2D-enhanced (post-cutout, transparent PNG). Set by the Background
  // Cutout skill via the "2dEnhance" agent path. Required input for the
  // 3D create path.
  enhancedImagePath  String?
  // Smart Image Picker's full candidate set (user uploads + downloaded
  // network images), with admin's per-item delete + primary toggle state.
  // See lib/skills/handlers/internal/smartImagePicker.ts for shape.
  candidateImages    Json?
  // Admin-curated supporting materials: webpage URLs, document/image/archive
  // uploads. Array of { kind, url?, path?, originalName?, addedAt }. Files
  // live under private/relics/<slug>/materials/.
  materials          Json?
  // The full DAG runLog from the most recent agent invocation, for the
  // admin trace viewer. Bounded by AgentJob limits upstream.
  pipelineTrace      Json?
  archivePath        String?
  derivedArchivePath String?
  loreEn             String?
  loreZh             String?
  passwordHash       String?
  extractedAt        DateTime?
  extractedById      String?
  extractedBy        User?                @relation("RelicExtractor", fields: [extractedById], references: [id], onDelete: SetNull)
  status             RelicStatus          @default(READY)
  draftNote          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  unlocks            RelicUnlock[]
  shares             RelicShare[]
  grants             RelicGrant[]
  jobs               RelicProcessingJob[]

  @@index([rarity])
  @@index([extractedAt])
  @@index([status])
}

model RelicGrant {
  id          String   @id @default(cuid())
  relicId     String
  userId      String
  grantedById String
  createdAt   DateTime @default(now())
  relic       Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)
  user        User     @relation("RelicGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User     @relation("RelicGrantGranter", fields: [grantedById], references: [id], onDelete: Cascade)

  @@unique([relicId, userId])
  @@index([userId])
}

model RelicShare {
  id         String   @id @default(cuid())
  relicId    String
  userId     String
  sharedById String
  createdAt  DateTime @default(now())
  relic      Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)
  user       User     @relation("RelicShareRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sharedBy   User     @relation("RelicShareGranter", fields: [sharedById], references: [id], onDelete: Cascade)

  @@unique([relicId, userId])
  @@index([userId])
}

enum RelicAction {
  CREATED
  EDITED
  MOVED
  RARITY_CHANGED
  SHARED
  SHARE_REVOKED
  EXTRACTED
  GRANTED
  GRANT_REVOKED
  PROCESSING_STARTED
  PROCESSING_STEP
  PROCESSING_SUCCEEDED
  PROCESSING_FAILED
}

enum RelicJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum RelicJobStep {
  ENQUEUED
  EXTRACT_ZIP
  PACK_DERIVED
  GENERATE_METADATA
  FINALIZE
}

model RelicProcessingJob {
  id           String         @id @default(cuid())
  relicId      String
  relic        Relic          @relation(fields: [relicId], references: [id], onDelete: Cascade)
  status       RelicJobStatus @default(PENDING)
  step         RelicJobStep   @default(ENQUEUED)
  progress     Int            @default(0)
  attempt      Int            @default(0)
  maxAttempts  Int            @default(3)
  errorMessage String?
  stepResults  Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, updatedAt])
  @@index([relicId])
}

// RelicDraft — the staging row created when an admin uploads a new relic.
// Holds AI-generated metadata + workspace files until the admin clicks
// "确认存入" in the preview modal, at which point a real Relic row is
// created (slot allocated then) and files renamed from _drafts/<id>/ to
// the final slug directory. Cancelling a draft removes the row + workspace.
//
// Crucially, NO Relic row exists during the draft phase — the vault grid
// merges drafts into the same view via slot, but they are clearly distinct
// entities. See lib/relics/pipeline/* for the runDraftPipeline flow that
// writes back to this table instead of Relic during the draft phase.
enum RelicDraftStatus {
  PENDING
  RUNNING
  READY_TO_REVIEW
  FAILED
  CANCELLED
}

model RelicDraft {
  id                String           @id @default(cuid())
  // Locked at upload time (admin clicks an empty grid cell). Unique guards
  // against two admins racing the same slot. Released when the draft is
  // confirmed (slot transfers to the new Relic row) or cancelled.
  slot              Int              @unique
  uploadedById      String?
  uploadedBy        User?            @relation("RelicDraftUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  draftNote         String?

  // Inlined job state — drafts don't get a separate RelicProcessingJob row.
  status            RelicDraftStatus @default(PENDING)
  step              RelicJobStep     @default(ENQUEUED)
  progress          Int              @default(0)
  errorMessage      String?
  attempt           Int              @default(0)
  maxAttempts       Int              @default(3)

  // Workspace = private/relics/_drafts/<id>/ — renamed to <finalSlug>/
  // on confirm. Other paths are derived but stored for fast lookup.
  workspaceDir      String?
  archivePath       String?
  extractedDir      String?
  derivedDir        String?

  // AI output (Researcher + Picker). Same shape as the corresponding Relic
  // columns; copied over verbatim on confirm.
  generatedMetadata Json?
  pipelineTrace     Json?
  stepResults       Json?

  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([uploadedById])
}

model RelicLog {
  // No FK to Relic — entries persist after EXTRACTED (relic row is deleted).
  // relicSlug + relicNameSnapshot keep orphans readable.
  id                 String      @id @default(cuid())
  relicId            String
  relicSlug          String
  relicNameSnapshot  String
  action             RelicAction
  actorId            String?
  actorNameSnapshot  String?
  targetUserId       String?
  targetNameSnapshot String?
  notes              String?
  details            Json?
  createdAt          DateTime    @default(now())

  @@index([relicId, createdAt])
  @@index([action, createdAt])
}

model RelicUnlock {
  id        String   @id @default(cuid())
  relicId   String
  cookieKey String
  createdAt DateTime @default(now())
  expiresAt DateTime
  relic     Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)

  @@unique([relicId, cookieKey])
  @@index([expiresAt])
}

enum AgentStatus {
  ONLINE
  STANDBY
  OFFLINE
}

enum AgentMode {
  MECHANICAL
  AUTONOMOUS
}

model Agent {
  id               String               @id @default(cuid())
  serial           Int?                 @unique
  codename         String               @unique
  nameEn           String
  nameZh           String
  codenameZh       String?
  mode             AgentMode           @default(MECHANICAL)
  status           AgentStatus         @default(STANDBY)
  avatarUrl        String
  descriptionEn    String?
  descriptionZh    String?
  syncLevel        Float                @default(0)
  matrixLevel      Int                  @default(1)
  // Admin-controlled display order in the /agent-control roster.
  // Lower value = higher in the list. Backfilled by
  // prisma/migrate-agent-display-order.ts to 0..N-1 sequence.
  displayOrder     Int                  @default(0)
  // Derived stats — see lib/agents/derived.ts (TODO). Stored as Int 0-100,
  // 0 means "not yet computed". Real algorithms ship in a later iteration.
  chaosLevel       Int                  @default(0)
  costTier         Int                  @default(0)
  activityLevel    Int                  @default(0)
  stabilityLevel   Int                  @default(0)
  // Central control slot data (one Json blob each, not skill references):
  //   pipelineConfig  → MECHANICAL workflow (nodes/edges/params)
  //   dispatcherConfig → AUTONOMOUS orchestrator (strategy/model/prompt)
  pipelineConfig   Json?
  dispatcherConfig Json?
  deployedAt       DateTime?
  // Capability tags ("image-cutout", "lore-writing", "metadata-derivation",
  // ...). Used by /agent-control?tab=scenes to filter which agents are
  // valid candidates for a given scene (an agent matches iff its tags ⊇
  // the scene's requiredCapabilities). Hand-curated by admin.
  capabilities     String[]             @default([])
  // Draft-phase scene claims. Multiple agents may claim the same sceneKey
  // here — exclusivity is only enforced at Deploy time, when the deploy
  // endpoint upserts the corresponding SceneBinding row (which IS unique
  // on sceneKey) and takes over from whichever agent previously owned it.
  // The BackboneFlowEditor reads this alongside SceneBinding to surface
  // scene-contract hints even before the agent is deployed.
  intentSceneKeys  String[]             @default([])
  skills           Json?
  skillEquips      AgentSkillEquip[]
  agentJobs        AgentJob[]
  sceneBindings    SceneBinding[]
  availableAp      Int                  @default(0)
  createdById      String?
  createdBy        User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([status, createdAt])
}

// AgentJob — async invocation record. Pattern mirrors RelicProcessingJob:
// fire-and-forget creation, status transitions PENDING → RUNNING → SUCCESS|FAILED,
// retries with exponential backoff for transient errors, and crash recovery
// for jobs left RUNNING by a previous server process.
//
// Phase 2 ships the scaffolding; the actual per-step execution lands in
// Phase 3 (Backbone, MECHANICAL) and Phase 4 (Orchestrator, AUTONOMOUS).
enum AgentJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model AgentJob {
  id           String          @id @default(cuid())
  agentId      String
  agent        Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Snapshot of the agent's mode at invocation time. Retries use this so
  // re-runs don't drift if the agent is edited between attempts.
  mode         AgentMode
  input        Json
  output       Json?
  status       AgentJobStatus  @default(PENDING)
  errorCode    String?
  errorMessage String?
  // Per-step execution log: array of { stepId, skillId, durationMs, ... }
  // Phase 3/4 runtimes append to this; Phase 2 leaves it empty.
  runLog       Json            @default(dbgenerated("'[]'::jsonb"))
  // Intra-step progress snapshot — populated by long-running skill handlers
  // (currently HTTP_API polling) via onProgress callback threaded from the
  // runner. percent is 0-100; label is a free-form stage string (e.g. Meshy's
  // status "PENDING"/"IN_PROGRESS"/"SUCCEEDED" or task_type). Frontend renders
  // both verbatim. Both nullable: most skills never emit. Cleared on retry.
  progressPercent Int?
  progressLabel   String?
  // Resume checkpoint for async polling skills (currently HTTP_API with
  // polling block, e.g. Meshy submit). Populated by runner after the skill's
  // POST returns but before polling completes; cleared on terminal status.
  // Shape: { stepId, skillSlug, initialResponse, createdAt }. On crash /
  // server restart, server-init re-queues these immediately (skip the 10min
  // stale threshold) and the skill handler skips the POST in favour of
  // continuing the original poll. TTL 6h; older checkpoints fall back to
  // a fresh submit. See lib/skills/runtime/runner.ts.
  resumeCheckpoint Json?
  attempts     Int             @default(0)
  maxAttempts  Int             @default(3)
  startedAt    DateTime?
  // Aligns with RelicProcessingJob.finishedAt + RelicDraft.finishedAt (same
  // concept across all three Job-shaped tables). DB column kept as "endedAt"
  // via @map for zero-downtime rename — actual ALTER TABLE deferred until
  // we're sure no external tool reads the old name.
  finishedAt   DateTime?       @map("endedAt")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Snapshot of the scene that triggered this job (e.g. "relic.create3d").
  // Used by runner.ts to derive the relic processing-log phase. NULL for
  // direct /api/agents/[id]/invoke calls (no scene). Was joined by the
  // Phase 7 Activity tab telemetry fields (actor / routedTo) — those have
  // been removed; sceneKey survives because it has a real runtime caller.
  sceneKey     String?

  @@index([status, updatedAt])
  @@index([agentId, createdAt])
}

enum SkillStatus {
  ONLINE
  OFFLINE
}

// SkillKind routes a Skill to an executor in lib/skills/handlers/. Was named
// HandlerKind pre-2026-05-10. The prior decorative SkillKind enum
// (PASSIVE/ACTIVE/ULTIMATE) and the INTERNAL runtime-injection kind
// (retired 2026-05-11) have both been removed.
// HTTP_API     → REST endpoint (e.g. Meshy, Stripe). handlerConfig: { method, url, authEnv, headers, bodyTemplate }
// LLM_PROMPT   → LLM call with prompt template. handlerConfig: { provider, model, systemPrompt, userTemplate, ... }
// MCP_SERVER   → remote MCP-protocol agent. handlerConfig: { serverUrl, toolName, authEnv }
enum SkillKind {
  HTTP_API
  LLM_PROMPT
  MCP_SERVER
}

model Skill {
  id            String             @id @default(cuid())
  // Stable machine identifier — used as LLM tool name (orchestrator) and
  // future admin URL slug. Decoupled from nameEn so renaming the display
  // name doesn't invalidate prompt caches / tool_use history. Optional
  // during rollout; auto-derived from nameEn on create when omitted.
  slug          String?            @unique @db.VarChar(64)
  level         Int                @default(1)
  icon          String             @db.VarChar(64)
  nameEn        String             @db.VarChar(80)
  nameZh        String             @db.VarChar(80)
  status        SkillStatus        @default(ONLINE)
  // Legacy AP cost — runtime never reads it. New admin UI hides the field;
  // column kept for back-compat / future quota system.
  costAp        Int                @default(0)
  descriptionEn String             @db.VarChar(2000)
  descriptionZh String             @db.VarChar(2000)
  // Runtime routing — see SkillKind comment above.
  kind          SkillKind          @default(MCP_SERVER)
  handlerConfig Json               @default(dbgenerated("'{}'::jsonb"))
  // JSON Schema describing input/output shapes. Used by invoke() for
  // validation and by Orchestrator to expose skills as LLM tools.
  inputSchema   Json?
  outputSchema  Json?
  createdById   String?
  createdBy     User?              @relation("SkillCreator", fields: [createdById], references: [id], onDelete: SetNull)
  equips        AgentSkillEquip[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([level])
  @@index([status])
  @@index([kind])
}

model AgentSkillEquip {
  id         String   @id @default(cuid())
  agentId   String
  agent      Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  // 0..5 — index of the spine/brain slot. NULL = legacy equip with no slot.
  // App-level uniqueness: at most one equip per (agentId, slotIndex) when
  // slotIndex is not null. Enforced in API transactions, not as a partial
  // unique index (db push doesn't carry one).
  slotIndex  Int?
  unlocked   Boolean  @default(false)
  equippedAt DateTime @default(now())

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([agentId, slotIndex])
  @@index([skillId])
}

// SceneBinding — admin-editable routing of a code-registered Scene
// (lib/<module>/scenes.ts → registerScene) to the Agent that satisfies it.
//
// The Scene definition (zod schemas, capability tags, label,
// prepareAgentInput) lives in code so type checks bite at build time.
// The CHOICE OF AGENT lives here so admin can rewire scenes without
// touching code (the entire point of the agent service).
//
// onDelete: Restrict on the agent FK is intentional — we don't want
// dropping an agent to silently break N scenes. The /agent-control delete
// flow surfaces "this agent has N bindings" before allowing the delete.
//
// 2026-05-11: outputMap column retired. scene.outputSchema is the
//             contract, agents self-shape via tail transforms.
// 2026-05-12: inputMap column retired. ctx → agent.input is now owned
//             by scene.prepareAgentInput in code (lib/<module>/scenes.ts).
//             Bindings are pure routing now.
model SceneBinding {
  id              String   @id @default(cuid())
  // Matches a SceneDefinition.key registered in code. Unique — one
  // binding per scene.
  sceneKey        String   @unique
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)
  enabled         Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentId])
  @@index([enabled])
}
