generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  serial            Int?              @unique
  // Tokens are stored as bcrypt hashes (one-way). tokenLookup is an
  // HMAC-SHA256(token, SAFETY_SECRET) for O(1) login lookup.
  // Plaintext is returned to admins exactly once at issuance.
  tokenHash         String
  tokenLookup       String            @unique
  name              String
  gender            String?
  avatarUrl         String?
  bio               String?
  level             Int               @default(1)
  attack            Int               @default(50)
  defense           Int               @default(50)
  hp                Int               @default(50)
  agility           Int               @default(50)
  luck              Int               @default(50)
  specialAttributes String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          Session[]
  activities        Activity[]
  relicShares       RelicShare[]      @relation("RelicShareRecipient")
  sharedByMe        RelicShare[]      @relation("RelicShareGranter")
  extractedRelics   Relic[]           @relation("RelicExtractor")
  relicGrants       RelicGrant[]      @relation("RelicGrantRecipient")
  grantsIssued      RelicGrant[]      @relation("RelicGrantGranter")
  vaultProfile      VaultProfile?
  vaultItems        VaultItem[]
  agentsCreated    Agent[]
  skillsCreated     Skill[]            @relation("SkillCreator")
}

// End-to-end encrypted vault — server stores only ciphertext.
// `salt` + `iterations` are public PBKDF2 parameters; `verifier` is
// HMAC-SHA256("verify", masterKey) so the client can self-check the entered
// master password without ever sending it (or anything derivable from it).
model VaultProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  saltBase64     String
  verifierBase64 String
  iterations     Int      @default(600000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum VaultItemKind {
  PASSWORD
  NOTE
}

model VaultItem {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           VaultItemKind
  dekCiphertext  String
  dekIv          String
  nameCiphertext String
  nameIv         String
  bodyCiphertext String
  bodyIv         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, updatedAt])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Drives detail-page rendering. Set by the Form Classifier skill in the
// relic scribe agent's DAG. Null = legacy / not yet classified — frontend
// falls back to the old "show all photos" treatment.
enum RelicFormKind {
  TWO_D
  THREE_D
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  SPECIAL
}

enum RelicStatus {
  DRAFT
  PROCESSING
  // Pipeline finished successfully but admin hasn't confirmed yet. Visible
  // only to admin (yellow-tinted cell in vault grid + review banner on
  // detail page). One-shot transition: confirming flips to READY.
  AWAITING_REVIEW
  READY
  PARTIAL
  FAILED
}

model Relic {
  id                 String               @id @default(cuid())
  slot               Int                  @unique
  slug               String               @unique
  nameEn             String
  nameZh             String
  classifEn          String
  classifZh          String
  rarity             Rarity
  iconKey            String?
  modelPath          String?
  // 2D form: composite/picked image rendered as the relic's hero. Set by
  // the Relic Image Pick skill (INTERNAL handler) on the 2D branch.
  primaryImagePath   String?
  // Set by the Form Classifier skill via the scribe agent. Drives the
  // detail page renderer (2D <img> vs 3D <model-viewer>).
  formKind           RelicFormKind?
  // The classifier's plain-language reason ("It's a watercolor painting,
  // best shown flat"), surfaced on the detail page for transparency.
  formReason         String?
  // The full DAG runLog from the most recent agent invocation, for the
  // admin trace viewer. Bounded by AgentJob limits upstream.
  pipelineTrace      Json?
  photoPaths         String[]
  archivePath        String?
  derivedArchivePath String?
  loreEn             String?
  loreZh             String?
  acquiredAt         DateTime?
  origin             String?
  passwordHash       String?
  extractedAt        DateTime?
  extractedById      String?
  extractedBy        User?                @relation("RelicExtractor", fields: [extractedById], references: [id], onDelete: SetNull)
  status             RelicStatus          @default(READY)
  draftNote          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  unlocks            RelicUnlock[]
  shares             RelicShare[]
  grants             RelicGrant[]
  jobs               RelicProcessingJob[]

  @@index([rarity])
  @@index([extractedAt])
  @@index([status])
}

model RelicGrant {
  id          String   @id @default(cuid())
  relicId     String
  userId      String
  grantedById String
  createdAt   DateTime @default(now())
  relic       Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)
  user        User     @relation("RelicGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User     @relation("RelicGrantGranter", fields: [grantedById], references: [id], onDelete: Cascade)

  @@unique([relicId, userId])
  @@index([userId])
}

model RelicShare {
  id         String   @id @default(cuid())
  relicId    String
  userId     String
  sharedById String
  createdAt  DateTime @default(now())
  relic      Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)
  user       User     @relation("RelicShareRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sharedBy   User     @relation("RelicShareGranter", fields: [sharedById], references: [id], onDelete: Cascade)

  @@unique([relicId, userId])
  @@index([userId])
}

enum RelicAction {
  CREATED
  EDITED
  MOVED
  RARITY_CHANGED
  SHARED
  SHARE_REVOKED
  EXTRACTED
  GRANTED
  GRANT_REVOKED
  PROCESSING_STARTED
  PROCESSING_STEP
  PROCESSING_SUCCEEDED
  PROCESSING_FAILED
}

enum RelicJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum RelicJobStep {
  ENQUEUED
  EXTRACT_ZIP
  PACK_DERIVED
  GENERATE_METADATA
  FINALIZE
}

model RelicProcessingJob {
  id           String         @id @default(cuid())
  relicId      String
  relic        Relic          @relation(fields: [relicId], references: [id], onDelete: Cascade)
  status       RelicJobStatus @default(PENDING)
  step         RelicJobStep   @default(ENQUEUED)
  progress     Int            @default(0)
  attempt      Int            @default(0)
  maxAttempts  Int            @default(3)
  errorMessage String?
  stepResults  Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, updatedAt])
  @@index([relicId])
}

model RelicLog {
  // No FK to Relic — entries persist after EXTRACTED (relic row is deleted).
  // relicSlug + relicNameSnapshot keep orphans readable.
  id                 String      @id @default(cuid())
  relicId            String
  relicSlug          String
  relicNameSnapshot  String
  action             RelicAction
  actorId            String?
  actorNameSnapshot  String?
  targetUserId       String?
  targetNameSnapshot String?
  notes              String?
  details            Json?
  createdAt          DateTime    @default(now())

  @@index([relicId, createdAt])
  @@index([action, createdAt])
}

model RelicUnlock {
  id        String   @id @default(cuid())
  relicId   String
  cookieKey String
  createdAt DateTime @default(now())
  expiresAt DateTime
  relic     Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)

  @@unique([relicId, cookieKey])
  @@index([expiresAt])
}

enum AgentStatus {
  ONLINE
  STANDBY
  OFFLINE
}

enum AgentMode {
  MECHANICAL
  AUTONOMOUS
}

model Agent {
  id               String               @id @default(cuid())
  serial           Int?                 @unique
  codename         String               @unique
  nameEn           String
  nameZh           String
  codenameZh       String?
  mode             AgentMode           @default(MECHANICAL)
  status           AgentStatus         @default(STANDBY)
  avatarUrl        String
  descriptionEn    String?
  descriptionZh    String?
  syncLevel        Float                @default(0)
  matrixLevel      Int                  @default(1)
  // Derived stats — see lib/agents/derived.ts (TODO). Stored as Int 0-100,
  // 0 means "not yet computed". Real algorithms ship in a later iteration.
  chaosLevel       Int                  @default(0)
  costTier         Int                  @default(0)
  activityLevel    Int                  @default(0)
  stabilityLevel   Int                  @default(0)
  // Central control slot data (one Json blob each, not skill references):
  //   pipelineConfig  → MECHANICAL workflow (nodes/edges/params)
  //   dispatcherConfig → AUTONOMOUS orchestrator (strategy/model/prompt)
  pipelineConfig   Json?
  dispatcherConfig Json?
  deployedAt       DateTime?
  skills           Json?
  skillEquips      AgentSkillEquip[]
  agentJobs        AgentJob[]
  availableAp      Int                  @default(0)
  createdById      String?
  createdBy        User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([status, createdAt])
}

// AgentJob — async invocation record. Pattern mirrors RelicProcessingJob:
// fire-and-forget creation, status transitions PENDING → RUNNING → SUCCESS|FAILED,
// retries with exponential backoff for transient errors, and crash recovery
// for jobs left RUNNING by a previous server process.
//
// Phase 2 ships the scaffolding; the actual per-step execution lands in
// Phase 3 (Backbone, MECHANICAL) and Phase 4 (Orchestrator, AUTONOMOUS).
enum AgentJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model AgentJob {
  id           String          @id @default(cuid())
  agentId      String
  agent        Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Snapshot of the agent's mode at invocation time. Retries use this so
  // re-runs don't drift if the agent is edited between attempts.
  mode         AgentMode
  input        Json
  output       Json?
  status       AgentJobStatus  @default(PENDING)
  errorCode    String?
  errorMessage String?
  // Per-step execution log: array of { stepId, skillId, durationMs, ... }
  // Phase 3/4 runtimes append to this; Phase 2 leaves it empty.
  runLog       Json            @default(dbgenerated("'[]'::jsonb"))
  attempts     Int             @default(0)
  maxAttempts  Int             @default(3)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, updatedAt])
  @@index([agentId, createdAt])
}

enum SkillKind {
  PASSIVE
  ACTIVE
  ULTIMATE
}

enum SkillStatus {
  ONLINE
  OFFLINE
}

// HandlerKind routes a Skill to an executor in lib/skills/handlers/.
// HTTP_API     → REST endpoint (e.g. Meshy, Stripe). handlerConfig: { method, url, authEnv, headers, bodyTemplate }
// LLM_PROMPT   → LLM call with prompt template. handlerConfig: { provider, model, systemPrompt, userTemplate, ... }
// MCP_SERVER   → remote MCP-protocol agent. handlerConfig: { serverUrl, toolName, authEnv } (Phase 5)
// INTERNAL     → in-repo function, dispatched by slug. handlerConfig: { handler: "<slug>", ...args }
enum HandlerKind {
  HTTP_API
  LLM_PROMPT
  MCP_SERVER
  INTERNAL
}

model Skill {
  id            String             @id @default(cuid())
  level         Int
  icon          String             @db.VarChar(64)
  nameEn        String             @db.VarChar(80)
  nameZh        String             @db.VarChar(80)
  kind          SkillKind
  status        SkillStatus        @default(ONLINE)
  costAp        Int                @default(0)
  descriptionEn String             @db.VarChar(2000)
  descriptionZh String             @db.VarChar(2000)
  // Runtime routing — see HandlerKind comment above.
  handlerKind   HandlerKind        @default(INTERNAL)
  handlerConfig Json               @default(dbgenerated("'{}'::jsonb"))
  // JSON Schema describing input/output shapes. Used by invoke() for
  // validation and by Orchestrator to expose skills as LLM tools.
  inputSchema   Json?
  outputSchema  Json?
  createdById   String?
  createdBy     User?              @relation("SkillCreator", fields: [createdById], references: [id], onDelete: SetNull)
  equips        AgentSkillEquip[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([kind])
  @@index([level])
  @@index([status])
  @@index([handlerKind])
}

model AgentSkillEquip {
  id         String   @id @default(cuid())
  agentId   String
  agent      Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  // 0..5 — index of the spine/brain slot. NULL = legacy equip with no slot.
  // App-level uniqueness: at most one equip per (agentId, slotIndex) when
  // slotIndex is not null. Enforced in API transactions, not as a partial
  // unique index (db push doesn't carry one).
  slotIndex  Int?
  unlocked   Boolean  @default(false)
  equippedAt DateTime @default(now())

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([agentId, slotIndex])
  @@index([skillId])
}
