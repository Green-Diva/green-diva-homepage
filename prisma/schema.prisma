generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  serial            Int?           @unique
  token             String         @unique
  name              String
  gender            String?
  avatarUrl         String?
  bio               String?
  level             Int            @default(1)
  attack            Int            @default(50)
  defense           Int            @default(50)
  hp                Int            @default(50)
  agility           Int            @default(50)
  luck              Int            @default(50)
  specialAttributes String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  sessions          Session[]
  activities        Activity[]
  relicShares       RelicShare[]   @relation("RelicShareRecipient")
  sharedByMe        RelicShare[]   @relation("RelicShareGranter")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  SPECIAL
}

model Relic {
  id           String        @id @default(cuid())
  slot         Int           @unique
  slug         String        @unique
  nameEn       String
  nameZh       String
  classifEn    String
  classifZh    String
  rarity       Rarity
  iconKey      String?
  modelPath    String?
  photoPaths   String[]
  loreEn       String?
  loreZh       String?
  acquiredAt   DateTime?
  origin       String?
  passwordHash String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  unlocks      RelicUnlock[]
  shares       RelicShare[]

  @@index([rarity])
}

model RelicShare {
  id          String   @id @default(cuid())
  relicId     String
  userId      String
  sharedById  String
  createdAt   DateTime @default(now())
  relic       Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)
  user        User     @relation("RelicShareRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sharedBy    User     @relation("RelicShareGranter", fields: [sharedById], references: [id], onDelete: Cascade)

  @@unique([relicId, userId])
  @@index([userId])
}

enum RelicAction {
  CREATED
  EDITED
  MOVED
  RARITY_CHANGED
  SHARED
  SHARE_REVOKED
  EXTRACTED
}

model RelicLog {
  // No FK to Relic — entries persist after EXTRACTED (relic row is deleted).
  // relicSlug + relicNameSnapshot keep orphans readable.
  id                 String      @id @default(cuid())
  relicId            String
  relicSlug          String
  relicNameSnapshot  String
  action             RelicAction
  actorId            String?
  actorNameSnapshot  String?
  targetUserId       String?
  targetNameSnapshot String?
  notes              String?
  details            Json?       // structured diff / before-after for EDITED/MOVED/RARITY_CHANGED
  createdAt          DateTime    @default(now())

  @@index([relicId, createdAt])
  @@index([action, createdAt])
}

model RelicUnlock {
  id        String   @id @default(cuid())
  relicId   String
  cookieKey String
  createdAt DateTime @default(now())
  expiresAt DateTime
  relic     Relic    @relation(fields: [relicId], references: [id], onDelete: Cascade)

  @@unique([relicId, cookieKey])
  @@index([expiresAt])
}
